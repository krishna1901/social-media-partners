# ─────────────────────────────────────────────────────────────────────────────
# SocialFlow AI — environment variables
# Copy to `.env.local` and fill in. With NO real Supabase values the app runs in
# "demo/preview mode" (no auth, demo data) so it still builds and previews.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — project "social" (ref: ttffcglpaurhlcwfeqqz)
# Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://ttffcglpaurhlcwfeqqz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only. ONLY needed for privileged/admin operations (never exposed to the
# client, never prefixed NEXT_PUBLIC_). Not required for the Phase 2 feature set.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Phase 3 placeholders (NOT used yet) ──────────────────────────────────────
# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Outbound webhooks
WEBHOOK_SECRET=
