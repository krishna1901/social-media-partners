# ─────────────────────────────────────────────────────────────────────────────
# SocialFlow AI — environment variables
# The app is LIVE-BY-DEFAULT: the public Supabase URL + anon key for the "social"
# project are baked into the code (src/lib/supabase/config.ts), so deployments
# connect to the live database with no env vars. Override the two values below to
# point at a different project, or set NEXT_PUBLIC_DEMO_MODE=true to force
# demo/preview mode (no auth, sample data) — useful for previews/forks.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — project "social" (ref: ttffcglpaurhlcwfeqqz). OPTIONAL overrides;
# leave blank to use the baked public defaults.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Set to "true" to force demo mode regardless of the baked config.
NEXT_PUBLIC_DEMO_MODE=

# Server-only. Required for the publishing job runner + maintenance cron (which
# run without a user session and bypass RLS) and the Stripe webhook. Never
# exposed to the client, never prefixed NEXT_PUBLIC_. Without it those background
# jobs are a safe no-op. SET THIS IN PRODUCTION for cron/webhooks to work.
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Deprecated (Phase 5): superseded by real Stripe Checkout (see below). Left for
# backward compatibility; the billing page no longer reads this.
NEXT_PUBLIC_UPGRADE_URL=

# ── AI content generation (Phase 3A) ────────────────────────────────────────
# Server-only keys (never prefixed NEXT_PUBLIC_). With NO key set, the Content
# Studio runs in demo mode and returns realistic sample output (build/preview
# stay green). Set either key to generate live content.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: pick the default provider ("openai" | "anthropic"). When unset, the
# app uses whichever key is present (Anthropic preferred).
AI_DEFAULT_PROVIDER=
# Optional: override the default model id (e.g. "claude-opus-4-8" or "gpt-4o-mini").
AI_DEFAULT_MODEL=

# ── Publishing job runner (Phase 3B) ────────────────────────────────────────
# Secret protecting the /api/cron/publish endpoint. When set, callers must send
# it as `Authorization: Bearer <secret>`. Vercel Cron sends this automatically.
CRON_SECRET=
# Set to "false" to disable simulated publishing (jobs then fail honestly until a
# real platform publisher is wired in). Defaults to simulate ON.
PUBLISH_SIMULATE=

# ── Social OAuth + token encryption (Phase 3C) ──────────────────────────────
# Secret used to encrypt OAuth tokens at rest (AES-256-GCM). Min 16 chars.
# Required to connect any social account. Keep it stable — rotating invalidates
# stored tokens (users must reconnect). SOCIAL_TOKEN_ENCRYPTION_KEY is an
# additive alias — set only ONE (TOKEN_ENCRYPTION_KEY wins if both are set, and
# they must hold the same value).
TOKEN_ENCRYPTION_KEY=
SOCIAL_TOKEN_ENCRYPTION_KEY=
# LinkedIn app (https://www.linkedin.com/developers/apps). Authorized redirect:
#   <NEXT_PUBLIC_APP_URL>/api/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional: override the LinkedIn callback URL (must match the app's registered
# redirect). Defaults to <NEXT_PUBLIC_APP_URL>/api/oauth/linkedin/callback.
LINKEDIN_REDIRECT_URI=
# Meta app (https://developers.facebook.com/apps) — Facebook Pages + Instagram
# Business publishing. Authorized redirect:
#   <NEXT_PUBLIC_APP_URL>/api/oauth/meta/callback
META_APP_ID=
META_APP_SECRET=
# Optional: override the Meta callback URL (must match the app's registered
# redirect). Defaults to <NEXT_PUBLIC_APP_URL>/api/oauth/meta/callback.
META_REDIRECT_URI=

# ── Additional platform OAuth + publishing (Phase 3G / Phase 6) ──────────────
# These connect accounts + store encrypted tokens AND drive real publishing
# (X text posts; TikTok/YouTube need a linked video asset). Live posting still
# needs each platform's approval (TikTok audit, X paid tier, YouTube upload
# scope); until connected, the runner simulates. Redirect: <APP_URL>/api/oauth/<id>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ── Stripe billing & checkout (Phase 5) ──────────────────────────────────────
# Server-only. With NO secret key set, billing runs in demo mode: the checkout /
# manage buttons are disabled and the app still builds & previews. We use hosted
# Stripe Checkout + Billing Portal (redirect flows), so NO publishable key /
# NEXT_PUBLIC_STRIPE_* is needed in the browser.
STRIPE_SECRET_KEY=
# Webhook signing secret. From `stripe listen` (local) or the Dashboard webhook
# endpoint. Required for /api/stripe/webhook to accept events.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_…, NOT prod_…) for each paid plan, matching the
# $29 / $99 monthly tiers in src/lib/billing/plans.ts. Starter is free (no price).
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Phase 3 placeholders (NOT used yet) ──────────────────────────────────────
# Outbound webhooks
WEBHOOK_SECRET=
